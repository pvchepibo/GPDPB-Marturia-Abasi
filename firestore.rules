rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: warta
    // Fields: title (string), content (string), date (string), category (string), authorUid (string)
    //
    // Collection: keuangan
    // Fields: description (string), amount (number), type (string), date (string), authorUid (string)
    //
    // Collection: users
    // Fields: email (string), role (string)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "agusthinuspaide@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(authorUid) {
      return isAuthenticated() && request.auth.uid == authorUid;
    }

    // Validation Functions
    function isValidWarta(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.date is string &&
             data.category in ['Ibadah', 'Kegiatan', 'Pengumuman'] &&
             data.authorUid == request.auth.uid;
    }

    function isValidKeuangan(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() < 200 &&
             data.amount is number && data.amount >= 0 &&
             data.type in ['Masuk', 'Keluar'] &&
             data.date is string &&
             data.authorUid == request.auth.uid;
    }

    function isValidUser(data) {
      return data.email is string && data.role in ['admin', 'user'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /warta/{wartaId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidWarta(request.resource.data);
      allow update: if isAdmin() && isValidWarta(request.resource.data);
      allow delete: if isAdmin();
    }

    match /keuangan/{transactionId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidKeuangan(request.resource.data);
      allow update: if isAdmin() && isValidKeuangan(request.resource.data);
      allow delete: if isAdmin();
    }

    match /uploads/{uploadId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can upload (jemaat)
      allow delete: if isAdmin();
    }

    match /prayer_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can submit (jemaat)
      allow delete: if isAdmin();
    }
  }
}
